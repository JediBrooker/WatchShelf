<drawables>
    <!-- Launcher/app icon. -->
    <bitmap id="launcher" filename="launcher_icon.png" dithering="none"/>

    <!-- Provider icon shown in the device media menu. A palette keeps it crisp
         on limited-color MIP displays. -->
    <bitmap id="providerIcon" filename="provider_icon.png" dithering="none">
        <palette>
            <color>000000</color>
            <color>FF8000</color>
            <color>FFFFFF</color>
        </palette>
    </bitmap>

    <!-- Placeholder book-cover glyph for menu rows whose real cover hasn't
         been fetched yet (or failed to). Same colors as the provider icon. -->
    <bitmap id="bookIcon" filename="book_icon.png" dithering="none"/>
</drawables>

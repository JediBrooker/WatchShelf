# The sidecar only needs ABS_URL - the watch talks ONLY to the sidecar (login,
# libraries, everything), so ABS itself never has to be exposed to the internet.
# Point this at ABS's address as seen from wherever the sidecar runs (an internal
# address is fine and preferred). No separate token/secret: the watch passes its
# own ABS login token per-request.
ABS_URL=http://127.0.0.1:13378
PORT=8081
# BIND=127.0.0.1   # set 0.0.0.0 in Docker
# BASE_PATH=/watchshelf-transcode  # prefix the sidecar strips; only matters if you mount it under a path instead of a subdomain
